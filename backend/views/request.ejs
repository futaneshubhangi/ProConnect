<h5>Connection Requests</h5>

<% if (requests.length === 0) { %>
  <p>No requests</p>
<% } %>

<% requests.forEach(user => { %>
  <div class="d-flex justify-content-between align-items-center mb-3">

    <div class="d-flex align-items-center">
      <img src="<%= user.profilePicture %>" width="45" class="rounded-circle me-2">
      <div>
        <strong><%= user.name %></strong><br>
        <small>@<%= user.username %></small>
      </div>
    </div>

    <div class="d-flex gap-2">

      <!-- Accept -->
      <form action="/user/accept_connection_request" method="POST">
        <input type="hidden" name="senderId" value="<%= user._id %>">
        <button class="btn btn-success btn-sm">Accept</button>
      </form>

      <!-- Reject -->
      <form action="/user/reject_connection_request" method="POST">
        <input type="hidden" name="senderId" value="<%= user._id %>">
        <button class="btn btn-danger btn-sm">Reject</button>
      </form>

    </div>

  </div>
<% }) %>