<div class="container mt-4" style="max-width: 700px;">

  <div class="card p-4 shadow-sm rounded-4 border-0">

    <h4 class="mb-3 text-center">Edit Profile</h4>

    <!-- PROFILE IMAGE SECTION -->
    <div class="text-center mb-4">

      <img 
        src="<%= user?.profilePicture || 'https://ui-avatars.com/api/?name=User' %>" 
        width="90"
        height="90"
        class="rounded-circle border mb-2"
        style="object-fit: cover;"
      >

      <form action="/user/update_profile" method="POST" enctype="multipart/form-data">
        <input type="file" name="profilePicture" class="form-control mb-2">
        <button class="btn btn-sm btn-outline-primary rounded-pill">
          Update Photo
        </button>
      </form>

    </div>

    <hr>

    <!-- PROFILE DATA FORM -->
    <form action="/user/update_profile_data" method="POST">

      <!-- NAME -->
      <div class="mb-3">
        <label class="form-label">Name</label>
        <input 
          type="text" 
          name="name" 
          class="form-control"
          value="<%= user?.name || '' %>"
        >
      </div>

      <!-- USERNAME -->
      <div class="mb-3">
        <label class="form-label">Username</label>
        <input 
          type="text" 
          name="username" 
          class="form-control"
          value="<%= user?.username || '' %>"
        >
      </div>

      <!-- BIO -->
      <div class="mb-3">
        <label class="form-label">Bio</label>
        <textarea name="bio" class="form-control"><%= profile?.bio || '' %></textarea>
      </div>

      <!-- CURRENT POSITION -->
      <div class="mb-3">
        <label class="form-label">Current Position</label>
        <input 
          type="text" 
          name="currentPost" 
          class="form-control"
          value="<%= profile?.currentPost || '' %>"
        >
      </div>

      <!-- SKILLS -->
      <div class="mb-3">
        <label class="form-label">Skills</label>
        <input 
          type="text" 
          name="skills" 
          class="form-control"
          placeholder="Java, Python, React"
          value="<%= profile?.skills ? profile.skills.join(', ') : '' %>"
        >
      </div>

      <!-- WORK -->
      <div class="mb-3">
        <label class="form-label">Work Experience</label>
        <div class="row">
          <div class="col">
            <input type="text" name="position" class="form-control" placeholder="Position">
          </div>
          <div class="col">
            <input type="text" name="company" class="form-control" placeholder="Company">
          </div>
          <div class="col">
            <input type="text" name="years" class="form-control" placeholder="Years">
          </div>
        </div>
      </div>

      <!-- EDUCATION -->
      <div class="mb-3">
        <label class="form-label">Education</label>
        <div class="row">
          <div class="col">
            <input type="text" name="degree" class="form-control" placeholder="Degree">
          </div>
          <div class="col">
            <input type="text" name="fieldOfStudy" class="form-control" placeholder="Field">
          </div>
          <div class="col">
            <input type="text" name="school" class="form-control" placeholder="College">
          </div>
        </div>
      </div>

      <!-- BUTTON -->
      <button class="btn btn-primary w-100 rounded-pill mt-3">
        Save Changes
      </button>

    </form>

  </div>

</div>