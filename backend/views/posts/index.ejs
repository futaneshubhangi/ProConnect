<div class="container mt-2" style="max-width: 2000px;">

  <div class="row g-3">

    <!-- LEFT SIDEBAR -->
    <div class="col-lg-3">

      <div class="card shadow-sm border-0 rounded-4 p-3 text-center"
      style="min-height: 220px;">

        <img 
          src="<%= user?.profilePicture || 'https://ui-avatars.com/api/?name=' + user?.username %>" 
          class="rounded-circle mx-auto mb-2"
          width="65"
          height="65"
        >

        <h6 class="mb-0 fw-semibold"><%= user?.username %></h6>

        <small class="text-muted d-block mb-2" style="font-size:12px;">
          <%= profile?.bio || "Add your bio" %>
        </small>

        <hr class="my-2">

        <p class="small mb-2">
          <strong><%= profile?.connections?.length || 0 %></strong> connections
        </p>

        <% if (user && user._id) { %>
          <a href="/profile/<%= user._id %>" class="btn btn-outline-primary btn-sm w-100 rounded-pill">
            View Profile
          </a>
        <% } %>

      </div>

    </div>

    <!-- CENTER FEED -->
    <div class="col-lg-6">

      <% if (!posts || posts.length === 0) { %>
        <div class="card p-3 text-center shadow-sm border-0 rounded-4">
          <p class="text-muted">No posts yet</p>
        </div>
      <% } %>

      <% posts.forEach(post => { %>

        <div class="card shadow-sm border-0 rounded-4 p-3 mb-3">

          <!-- HEADER -->
          <div class="d-flex align-items-center gap-2 mb-2">

            <img 
              src="<%= post.userId?.profilePicture || 'https://ui-avatars.com/api/?name=' + post.userId?.username %>" 
              class="rounded-circle"
              width="40"
              height="40"
            >

            <div>
              <a href="/profile/<%= post.userId._id %>" class="text-dark text-decoration-none fw-semibold">
                <%= post.userId.username %>
              </a>
              <br>
              
            </div>

          </div>

          <!-- CONTENT -->
          <p class="mb-2" style="
            max-height:60px;
            overflow:hidden;
            text-overflow:ellipsis;
            display:-webkit-box;
            -webkit-line-clamp:3;
            -webkit-box-orient:vertical;
          ">
            <%= post.body %>
          </p>

          <!-- MEDIA -->
          <% if(post.media){ %>

            <% if(post.media.match(/\.(mp4|webm|ogg)$/i)) { %>

              <video controls class="w-100 rounded mb-2" style="max-height:300px; object-fit:cover;">
                <source src="<%= post.media %>">
              </video>

            <% } else { %>

              <img 
              src="<%= post.media %>" 
              class="img-fluid rounded mb-2"
              style="max-height:300px; width:100%; object-fit:cover;"
            >
            <% } %>

          <% } %>

          <!-- LIKE BUTTON (SAFE FIX) -->
          <% 
            let isLiked = false;
            if (userId && post.likes) {
              isLiked = post.likes.some(
                id => id && id.toString() === userId.toString()
              );
            }
          %>

          <form action="/post/like/<%= post._id %>" method="POST">
            <button class="btn btn-light btn-sm rounded-pill">
              <% if (isLiked) { %> ❤️ <% } else { %> 👍 <% } %>
              <%= post.likes?.length || 0 %>
            </button>
          </form>

          <!-- COMMENT FORM -->
          <form action="/post/comment/<%= post._id %>" method="POST" class="mt-2">
            <div class="d-flex gap-2">
              <input 
                type="text" 
                name="body"
                class="form-control form-control-sm"
                placeholder="Write a comment..."
                required
              >
              <button class="btn btn-primary btn-sm">Post</button>
            </div>
          </form>

          <!-- SHOW COMMENTS -->
          <div class="mt-2">

            <% comments
              .filter(c => c.postId.toString() === post._id.toString())
              .forEach(comment => { %>

              <div class="d-flex gap-2 mb-2">

                <img 
                  src="<%= comment.userId?.profilePicture || 'https://ui-avatars.com/api/?name=' + comment.userId?.username %>" 
                  width="30"
                  height="30"
                  class="rounded-circle"
                >

                <div class="bg-light p-2 rounded w-100">

                  <strong style="font-size:13px;">
                    <%= comment.userId?.username %>
                  </strong>

                  <p class="mb-1" style="font-size:13px;">
                    <%= comment.body %>
                  </p>

                  <% if (userId && comment.userId._id.toString() === userId.toString()) { %>
                    <form action="/post/comment/<%= comment._id %>?_method=DELETE" method="POST">
                      <button class="btn btn-sm text-danger p-0">delete</button>
                    </form>
                  <% } %>

                </div>

              </div>

            <% }) %>

          </div>

        </div>

      <% }) %>

    </div>

    <!-- RIGHT SIDEBAR -->
    <div class="col-lg-3">

      <div class="card shadow-sm border-0 rounded-4 p-3">

        <h6 class="mb-3 fw-semibold">People you may know</h6>

        <div class="d-flex justify-content-between mb-2">
          <span class="small">Aditya</span>
          <button class="btn btn-outline-primary btn-sm rounded-pill">Connect</button>
        </div>

        <div class="d-flex justify-content-between">
          <span class="small">Saurabh</span>
          <button class="btn btn-outline-primary btn-sm rounded-pill">Connect</button>
        </div>

      </div>

    </div>

  </div>

</div>